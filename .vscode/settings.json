{
  "files.encoding": "utf8",
  "terminal.integrated.defaultProfile.windows": "PowerShell UTF-8",
  "terminal.integrated.profiles.windows": {
    "PowerShell UTF-8": {
      "source": "PowerShell",
      "args": [
        "-NoExit",
        "-Command",
        "chcp 65001 | Out-Null; [Console]::InputEncoding = [Text.UTF8Encoding]::new(); [Console]::OutputEncoding = [Text.UTF8Encoding]::new()"
      ]
    }
  }
}
